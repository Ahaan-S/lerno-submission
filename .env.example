NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── OpenAI (embeddings only) ───────────────────────────────────────────────────
# Required for text-embedding-3-small in lib/ai/embed.ts
OPENAI_API_KEY=sk-...your-openai-api-key

# ── Qdrant (vector search) ─────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key

# App filters match root OR metadata.* for grade/subject/chapter — no extra env needed.
# Run npm run qdrant:setup once on your cluster for keyword + full-text indexes.

# ═══════════════════════════════════════════════════════════════════════════════
# Google LLM — two different products (do not mix keys):
#
#   A) AI Studio  →  GEMINI_API_KEY  →  aistudio.google.com / generativelanguage API
#   B) Vertex AI    →  Google Cloud project  →  aiplatform.googleapis.com (uses credits)
#
# ── Vertex AI (recommended with GCP $300 / programme credits) ───────────────────
#
# Step 1: In Google Cloud Console, pick your Project, note the Project ID (e.g. gen-lang-client-...).
# Step 2: Enable "Vertex AI API" (APIs & Services → Library).
# Step 3: GCP_REGION — your project does NOT have one "remembered" region. You choose a
#         region for API calls. Common: us-central1 or asia-south1. Use the same value in
#         GCP_REGION everywhere; Gemini on Vertex is available in these regions.
# Step 4 — auth (pick ONE):
#
#   • EASIEST: API key from Google Cloud → APIs & Services → Credentials → Create credential
#     → API key, restrict to "Vertex AI API". Click "Show key" and copy the string.
VERTEX_AI_API_KEY=
#     (Google’s docs sometimes call this GOOGLE_API_KEY — we accept either if you also set
#      GCP_PROJECT_ID + GCP_REGION.)
#
#   • PRODUCTION: Create a Service Account → grant "Vertex AI User" → create JSON key
#     → paste entire JSON as one line into GCP_SERVICE_ACCOUNT_JSON (Vercel secret).
#
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Local only: GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json

# Models (Vertex OpenAI-compat — no "preview" defaults in code):
#   CHAT/VISION = main tutor, grading, diagnostics, memory extraction | LITE = query rewriter only
GEMINI_CHAT_MODEL=google/gemini-2.5-flash
# Optional cheaper rewrite model where Vertex exposes it (some regions return 404 for flash-lite):
# GEMINI_LITE_MODEL=google/gemini-2.5-flash-lite
GEMINI_LITE_MODEL=google/gemini-2.5-flash
GEMINI_VISION_MODEL=google/gemini-2.5-flash

# ── AI Studio only (legacy / local test) ───────────────────────────────────────
# If Vertex vars above are NOT set, the app can use:
# GEMINI_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# Supabase Edge Function: update-student-memory (calls your Next.js app, not Gemini directly)
#
# The edge runtime cannot use Vertex service-account auth easily, so it POSTs to:
#   POST {LERNO_APP_URL}/api/internal/llm-chat
#
# LERNO_INTERNAL_LLM_SECRET — long random string YOU invent. Same value must be set in:
#   • Vercel (or .env.local) for the Next.js app
#   • Supabase → Project Settings → Edge Functions → Secrets
#   This proves the request to /api/internal/llm-chat is from your Supabase function, not the public internet.
#
# LERNO_APP_URL — public base URL of this Next app, no trailing slash (e.g. https://xxx.vercel.app).
#                 Only needed in Supabase secrets for the edge function.
#
LERNO_INTERNAL_LLM_SECRET=generate-a-long-random-string

# ── Supabase Storage ───────────────────────────────────────────────────────────
ATTACHMENT_BUCKET=chat-attachments
SARVAM_API_KEY=your-api-key

# ═══════════════════════════════════════════════════════════════════════════════
# Feedback email notifications — Resend (resend.com, free tier: 100 emails/day)
# Sign up at resend.com → API Keys → Create API Key
# FEEDBACK_NOTIFY_EMAILS — comma-separated list of emails to notify on new feedback
# FEEDBACK_FROM_EMAIL — verified sender domain address (e.g. noreply@yourdomain.com)
RESEND_API_KEY=re_...
FEEDBACK_NOTIFY_EMAILS=you@example.com,dev@example.com
FEEDBACK_FROM_EMAIL=noreply@lerno.in
# ── Supabase Dashboard → Edge Functions → Secrets (not in .env for local Next) ──
# LERNO_APP_URL=https://your-app.vercel.app
# LERNO_INTERNAL_LLM_SECRET=same-as-above
# GEMINI_CHAT_MODEL=optional; defaults to google/gemini-2.5-flash in code

# ═══════════════════════════════════════════════════════════════════════════════
# Rate limiting — Upstash Redis (free tier: 10k cmds/day)
# Sign up at upstash.com → create a Redis database → copy REST URL + token.
# If not set, rate limiting is disabled (open access — ok for local dev).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# ═══════════════════════════════════════════════════════════════════════════════
# Error monitoring — Sentry
# Sign up at sentry.io → create a Next.js project → copy the DSN.
#
# All 5 vars go in a single .env — no separate file needed.
#
# 1. NEXT_PUBLIC_SENTRY_DSN + SENTRY_DSN
#    Same value. Get it from: sentry.io → your project → Settings → Client Keys (DSN)
#    NEXT_PUBLIC_ prefix makes it available in the browser bundle too.
#
# 2. SENTRY_ORG
#    Your organisation slug. Find it in the URL when logged in:
#    sentry.io/organizations/YOUR-ORG-SLUG/
#
# 3. SENTRY_PROJECT
#    Your project slug. Find it at:
#    sentry.io → Settings → Projects → click your project → slug shown under the name
#
# 4. SENTRY_AUTH_TOKEN  ← the only secret here, keep it out of git
#    Generate at: sentry.io/settings/auth-tokens/
#    Click "Create New Token" → tick scopes: project:releases + org:read → copy token
#    Used only at build time to upload source maps (readable stack traces in production).
#    Without it, errors still capture fine but stack traces show minified code.
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
SENTRY_DSN=https://xxx@oyyy.ingest.sentry.io/zzz
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=sntrys_eyJ...


# Feedback email notifications — add your Resend key + team emails
# Get API key from: resend.com → API Keys
RESEND_API_KEY=re_...
FEEDBACK_NOTIFY_EMAILS=you@yourdomain.com,dev@yourdomain.com
FEEDBACK_FROM_EMAIL=noreply@lerno.in